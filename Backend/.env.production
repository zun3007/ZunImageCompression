NODE_ENV=production
PORT=3000
HOST=0.0.0.0
REDIS_URL=redis://redis:6379
APP_BASE_URL=http://localhost:3000
SWAGGER_ENABLED=true
SWAGGER_ROUTE_PREFIX=/docs
UPLOAD_TMP_DIR=.data/uploads
ARTIFACT_DIR=.data/artifacts
ARTIFACT_TTL_SECONDS=86400
MAX_UPLOAD_FILE_SIZE=26214400
MAX_FILES_PER_JOB=10
QUEUE_CONCURRENCY=4
JOB_ATTEMPTS=3
JOB_BACKOFF_MS=1000
JOB_REMOVE_ON_COMPLETE_AGE=86400
JOB_REMOVE_ON_FAIL_AGE=86400
